# ──────────────────────────────────────────────────────────────
# TRTC AI Voice Agent Demo — credentials
#
# 1. Copy this file to `.env`
# 2. Fill in the values below
# 3. Run `npm run dev`
#
# `.env` is gitignored — never commit real credentials.
# ──────────────────────────────────────────────────────────────

# ─── TRTC application ─────────────────────────────────────────
# Create an app in the TRTC Console (https://console.trtc.io)
# then copy its SDKAppID and SDKSecretKey here.
TRTC_SDK_APP_ID=1400000000
TRTC_SDK_SECRET_KEY=your_trtc_sdk_secret_key

# ─── Tencent Cloud API keys ───────────────────────────────────
# Used by the local server to call the Conversational AI REST API
# (StartAIConversation / StopAIConversation).
# Get them from the CAM Console → API Keys (https://console.tencentcloud.com/cam/capi)
TENCENT_SECRET_ID=AKIDxxxxxxxxxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxxxxxxxxxx

# Region to call the TRTC API in. Pick the one closest to you.
# Common values: ap-singapore, ap-jakarta, ap-bangkok, na-siliconvalley
TENCENT_API_REGION=ap-singapore

# ─── LLM (the agent's brain) ──────────────────────────────────
# Any OpenAI-compatible /chat/completions endpoint works:
# OpenAI, DeepSeek, Groq, a self-hosted model, etc.
# TRTC's cloud calls this endpoint directly, so it must be
# reachable from the public internet.
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-llm-api-key
LLM_MODEL=gpt-4o-mini

# ─── Speech-to-Text (the agent's ears) ────────────────────────
# Language the user will speak. Uses TRTC's built-in ASR, no
# extra credentials needed. Examples: en, zh, ja, ko, th, id, ms
ASR_LANGUAGE=en

# ─── Text-to-Speech (the agent's voice) ───────────────────────
# Pick ONE provider: tencent | minimax | elevenlabs
TTS_PROVIDER=tencent

# Option A — Tencent TTS (simplest: reuses the API keys above).
# TENCENT_APP_ID is your account-level AppID, shown at
# https://console.tencentcloud.com/developer
# Browse voices: https://www.tencentcloud.com/document/product/1073/34112
TENCENT_APP_ID=1300000000
TENCENT_TTS_VOICE_TYPE=101051

# Option B — MiniMax TTS (uncomment TTS_PROVIDER=minimax to use)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_VOICE_ID=English_expressive_narrator

# Option C — ElevenLabs TTS (uncomment TTS_PROVIDER=elevenlabs to use)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Local server ─────────────────────────────────────────────
SERVER_PORT=3001
